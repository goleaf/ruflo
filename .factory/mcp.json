{
    "mcpServers": {
        "laravel-boost": {
            "type": "stdio",
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "ruflo": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "--yes",
                "ruflo@latest",
                "mcp",
                "start"
            ]
        }
    }
}
